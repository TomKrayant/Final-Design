<!--pages/user/user.wxml-->
<view class="user-page">
  <view class="user-hero">
    <text class="hero-title">宠物资料</text>
    <text class="hero-desc">在这里修改主页展示的宠物基础信息</text>
  </view>

  <view class="editor-card">
    <view class="avatar-area">
      <image class="avatar-image" src="{{petProfile.avatar}}" mode="aspectFill"></image>
      <view class="avatar-copy">
        <text class="avatar-title">宠物头像</text>
      </view>
      <button class="avatar-btn" bindtap="changeAvatar">更换头像</button>
    </view>

    <view class="field-list">
      <view class="field">
        <text class="field-label">宠物名字</text>
        <input
          class="field-input"
          value="{{petProfile.name}}"
          data-field="name"
          placeholder="请输入宠物名字"
          bindinput="handleInputChange"
        />
      </view>

      <view class="field">
        <text class="field-label">宠物品种</text>
        <input
          class="field-input"
          value="{{petProfile.type}}"
          data-field="type"
          placeholder="请输入宠物品种"
          bindinput="handleInputChange"
        />
      </view>

      <view class="field">
        <text class="field-label">宠物性别</text>
        <input
          class="field-input"
          value="{{petProfile.gender}}"
          data-field="gender"
          placeholder="请输入宠物性别"
          bindinput="handleInputChange"
        />
      </view>

      <view class="field">
        <text class="field-label">宠物年龄</text>
        <input
          class="field-input"
          value="{{petProfile.age}}"
          data-field="age"
          placeholder="请输入宠物年龄"
          bindinput="handleInputChange"
        />
      </view>

      <view class="field">
        <text class="field-label">宠物体重</text>
        <input
          class="field-input"
          value="{{petProfile.weight}}"
          data-field="weight"
          placeholder="请输入宠物体重"
          bindinput="handleInputChange"
        />
      </view>
    </view>

    <view class="action-row">
      <button class="reset-btn" bindtap="resetPetProfile">恢复默认</button>
      <button class="save-btn" bindtap="savePetProfile">保存修改</button>
    </view>
  </view>

  <button class="logout-btn" bindtap="handleLogout">退出登录</button>
</view>
