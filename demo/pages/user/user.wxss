/* pages/user/user.wxss */
.user-page {
  min-height: 100vh;
  padding: 36rpx 24rpx 48rpx;
  background: linear-gradient(180deg, #eef7f4 0%, #f7fbfa 52%, #f2f6f5 100%);
  box-sizing: border-box;
}

.user-hero {
  margin-bottom: 24rpx;
  padding: 12rpx 6rpx;
}

.hero-title {
  display: block;
  color: #1f3532;
  font-size: 46rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  color: #70817d;
  font-size: 24rpx;
  line-height: 1.6;
}

.editor-card {
  padding: 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(27, 54, 50, 0.08);
}

.avatar-area {
  display: flex;
  align-items: center;
  padding-bottom: 26rpx;
  border-bottom: 1rpx solid #edf1f0;
}

.avatar-image {
  width: 124rpx;
  height: 124rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.avatar-copy {
  flex: 1;
  margin-left: 22rpx;
  margin-right: 20rpx;
}

.avatar-title {
  display: block;
  color: #213532;
  font-size: 30rpx;
  font-weight: 700;
}

.avatar-desc {
  display: block;
  margin-top: 10rpx;
  color: #7e8c8a;
  font-size: 22rpx;
  line-height: 1.6;
}

.avatar-btn {
  margin: 0;
  padding: 0 26rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: #e9f4f0;
  color: #1f5f5b;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.field-list {
  margin-top: 10rpx;
}

.field {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  color: #526562;
  font-size: 25rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  background: #f5f8f7;
  color: #223633;
  font-size: 26rpx;
  box-sizing: border-box;
}

.action-row {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
}

.reset-btn,
.save-btn {
  width: calc(50% - 10rpx);
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.reset-btn {
  background: #edf4f2;
  color: #1f5f5b;
}

.save-btn {
  background: linear-gradient(135deg, #1f5f5b 0%, #3a8d80 100%);
  color: #ffffff;
}

.logout-btn {
  margin-top: 28rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5e6e6b;
  font-size: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(27, 54, 50, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.avatar-btn::after,
.reset-btn::after,
.save-btn::after,
.logout-btn::after {
  border: none;
}
