/* pages/home/home.wxss */
.home-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #eef8f4 0%, #f7fbfa 45%, #f4f7f8 100%);
  box-sizing: border-box;
}

.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #1f5f5b 0%, #3b8b7f 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(31, 95, 91, 0.18);
}

.hero-copy {
  flex: 1;
  padding-right: 24rpx;
}

.hero-eyebrow {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  opacity: 0.92;
}

.hero-status {
  display: inline-flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #7ef0bf;
}

.status-text {
  font-size: 24rpx;
}

.hero-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.2);
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  color: #203230;
  font-size: 32rpx;
  font-weight: 700;
}

.section-desc {
  color: #7b8b88;
  font-size: 22rpx;
}

.metrics-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.metric-card,
.overview-card,
.module-card {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(25, 46, 44, 0.08);
}

.metric-card {
  box-sizing: border-box;
  width: calc(50% - 10rpx);
  margin-bottom: 20rpx;
  padding: 26rpx;
  min-height: 260rpx;
}

.metric-icon {
  position: absolute;
  left: 250rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #eaf7f4;
  color: #1f5f5b;
  font-size: 24rpx;
  font-weight: 700;
}

.metric-label {
  display: flex;
  color: #687775;
  font-size: 24rpx;
}

.metric-il {
  display: flex;
}

.metric-value-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.metric-value {
  color: #1c302e;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1;
}

.metric-unit {
  margin-left: 10rpx;
  color: #6b7b79;
  font-size: 22rpx;
}

.metric-desc {
  display: block;
  width: 72%;
  margin-top: 25rpx;
  color: #7e8b89;
  font-size: 22rpx;
  line-height: 1.6;
}

.metric-image {
  position: absolute;
  right: 0rpx;
  bottom: 0rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  
}

.overview-list,
.module-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.overview-card {
  padding: 28rpx;
}

.overview-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.overview-title {
  color: #4f6260;
  font-size: 26rpx;
}

.overview-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef8f4;
  color: #1f5f5b;
  font-size: 20rpx;
}

.overview-value {
  display: block;
  margin-top: 18rpx;
  color: #1d2f2d;
  font-size: 42rpx;
  font-weight: 700;
}

.overview-detail {
  display: block;
  margin-top: 10rpx;
  color: #7c8b89;
  font-size: 24rpx;
  line-height: 1.7;
}

.module-card {
  display: flex;
  align-items: center;
  padding: 22rpx;
}

.module-image {
  width: 108rpx;
  height: 108rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.module-copy {
  margin-left: 22rpx;
}

.module-title {
  display: block;
  color: #203230;
  font-size: 28rpx;
  font-weight: 700;
}

.module-detail {
  display: block;
  margin-top: 10rpx;
  color: #7e8c8a;
  font-size: 23rpx;
  line-height: 1.6;
}
