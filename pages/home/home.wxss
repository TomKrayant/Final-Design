/* pages/home/home.wxss */
.home-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #eef8f4 0%, #f7fbfa 45%, #f4f7f8 100%);
  box-sizing: border-box;
}

.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #1f5f5b 0%, #3b8b7f 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(31, 95, 91, 0.18);
}

.hero-copy {
  flex: 1;
  padding-right: 24rpx;
}

.hero-eyebrow {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 700;
}

.hero-profile {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.hero-profile-item {
  width: 50%;
  margin-top: 14rpx;
}

.hero-profile-label {
  display: block;
  font-size: 20rpx;
  opacity: 0.8;
}

.hero-profile-value {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.hero-status {
  display: inline-flex;
  align-items: center;
  margin-top: 26rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #7ef0bf;
}

.status-text {
  font-size: 24rpx;
}

.hero-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  color: #203230;
  font-size: 32rpx;
  font-weight: 700;
}

.section-desc {
  color: #7b8b88;
  font-size: 22rpx;
}

.metrics-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.metric-card,
.overview-card,
.map-card {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(25, 46, 44, 0.08);
}

.metric-card {
  box-sizing: border-box;
  width: calc(50% - 10rpx);
  margin-bottom: 20rpx;
  padding: 26rpx;
  height: 260rpx;
}

.metric-icon {
  position: absolute;
  left: 250rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #eaf7f4;
  color: #1f5f5b;
  font-size: 24rpx;
  font-weight: 700;
}

.metric-label {
  display: flex;
  color: #687775;
  font-size: 24rpx;
}

.metric-il {
  display: flex;
}

.metric-value-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.metric-dual-block {
  margin-top: 14rpx;
  width: 72%;
}

.metric-dual-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  margin-top: 10rpx;
}

.metric-dual-row:first-child {
  margin-top: 0;
}

.metric-dual-label {
  color: #687775;
  font-size: 22rpx;
  width: 64rpx;
  margin-right: 12rpx;
}

.metric-dual-value-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
}

.metric-dual-value {
  color: #1c302e;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.metric-dual-unit {
  margin-left: 8rpx;
  color: #6b7b79;
  font-size: 20rpx;
}

.metric-value {
  color: #1c302e;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1;
}

.metric-unit {
  margin-left: 10rpx;
  color: #6b7b79;
  font-size: 22rpx;
}

.metric-desc {
  display: block;
  width: 72%;
  margin-top: 25rpx;
  color: #7e8b89;
  font-size: 22rpx;
  line-height: 1.6;
}

.metric-image {
  position: absolute;
  right: 0rpx;
  bottom: 0rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
}

.posture-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.posture-summary-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(25, 46, 44, 0.08);
}

.posture-summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.posture-summary-title {
  color: #4f6260;
  font-size: 26rpx;
}

.posture-summary-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef8f4;
  color: #1f5f5b;
  font-size: 20rpx;
}

.posture-summary-value {
  display: block;
  margin-top: 18rpx;
  color: #1d2f2d;
  font-size: 42rpx;
  font-weight: 700;
}

.posture-summary-detail {
  display: block;
  margin-top: 10rpx;
  color: #7c8b89;
  font-size: 24rpx;
  line-height: 1.7;
}

.posture-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.posture-card {
  flex: 1;
  padding: 24rpx 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(25, 46, 44, 0.08);
  text-align: center;
  box-sizing: border-box;
}

.posture-card-active {
  background: linear-gradient(180deg, #edf7f3 0%, #ffffff 100%);
  border: 2rpx solid #8dd2bf;
}

.posture-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
}

.posture-card-title {
  display: block;
  margin-top: 16rpx;
  color: #203230;
  font-size: 26rpx;
  font-weight: 700;
}

.posture-card-desc {
  display: block;
  margin-top: 10rpx;
  color: #738481;
  font-size: 21rpx;
  line-height: 1.5;
}

.map-card {
  padding: 24rpx;
}

.map-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.map-title {
  display: block;
  color: #203230;
  font-size: 30rpx;
  font-weight: 700;
}

.map-detail {
  display: block;
  margin-top: 10rpx;
  color: #7b8b88;
  font-size: 22rpx;
  line-height: 1.6;
}

.map-chip {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #edf6f3;
  color: #1f5f5b;
  font-size: 20rpx;
}

.gps-map {
  width: 100%;
  height: 360rpx;
  margin-top: 22rpx;
  border-radius: 24rpx;
}

.map-info-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.map-info-item {
  flex: 1;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f6f9f8;
}

.map-info-label {
  display: block;
  color: #7a8a87;
  font-size: 21rpx;
}

.map-info-value {
  display: block;
  margin-top: 10rpx;
  color: #1d302d;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}
